page {
  --primary: #2c9678;
  --primary-dark: #237a60;
  --bg: #f5f7fa;
  --card-bg: #ffffff;
  --text: #333333;
  --text-secondary: #666666;
  --border: #e5e5e5;
  --radius: 16rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  background-color: var(--bg);
  color: var(--text);
}

.container {
  padding: 30rpx;
}

.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--text);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: 30rpx;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.form-input {
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  line-height: 80rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border);
}

.text-right {
  text-align: right;
}

.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.flex {
  display: flex;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(44, 150, 120, 0.1);
  color: var(--primary);
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
}
