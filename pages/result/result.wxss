.result-header {
  text-align: center;
  padding: 30rpx 0 10rpx;
}

.result-community {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}

.result-meta {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.highlight {
  text-align: center;
  padding: 50rpx 30rpx;
}

.highlight-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.highlight-price {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
}

.highlight-range {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

.highlight-unit {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.method-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.method-item:last-child {
  border-bottom: none;
}

.method-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.method-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.method-weight {
  font-size: 24rpx;
  color: var(--primary);
  background: rgba(44, 150, 120, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.method-desc {
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 6rpx;
}

.method-formula {
  font-size: 24rpx;
  color: #999;
}

.coef-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.coef-row.total {
  border-top: 2rpx solid var(--border);
  border-bottom: none;
  margin-top: 10rpx;
  font-weight: 600;
}

.coef-name {
  color: var(--text-secondary);
}

.coef-value {
  color: var(--text);
  font-variant-numeric: tabular-nums;
}

.disclaimer-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.disclaimer-content view {
  margin-bottom: 10rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  color: var(--text);
  border-radius: 12rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border);
}

.btn-secondary.primary {
  background: var(--primary);
  color: #fff;
  border: none;
}

.safe-bottom {
  height: 40rpx;
}
