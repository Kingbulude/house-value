{
  "compilerOptions": {
    "target": "ES2015",
    "module": "CommonJS",
    "strict": true,
    "noImplicitThis": false,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2015", "DOM"],
    "typeRoots": ["./types"]
  },
  "include": [
    "app.ts",
    "pages/**/*.ts",
    "utils/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
